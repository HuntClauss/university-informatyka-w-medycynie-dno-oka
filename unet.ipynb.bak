   "source": [
    "import os\n",
    "import random\n",
    "import numpy as np\n",
    "import cv2\n",
    "from skimage.exposure import equalize_adapthist\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from PIL import Image\n",
    "from pathlib import Path\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import Dataset, DataLoader\n",
    "import torchvision.transforms.functional as TF\n",
    "\n",
    "from sklearn.metrics import accuracy_score, f1_score, jaccard_score, confusion_matrix\n",
    "\n",
    "# Set seeds for reproducibility\n",
    "def set_seed(seed=42):\n",
    "    random.seed(seed)\n",
    "    os.environ[\"PYTHONHASHSEED\"] = str(seed)\n",
    "    np.random.seed(seed)\n",
    "    torch.manual_seed(seed)\n",
    "    torch.cuda.manual_seed(seed)\n",
    "    torch.cuda.manual_seed_all(seed)\n",
    "    torch.backends.cudnn.deterministic = True\n",
    "    torch.backends.cudnn.benchmark = False\n",
    "\n",
    "set_seed(42)\n",
    "\n",
    "# Device setup and resource management\n",
    "use_cuda = torch.cuda.is_available()\n",
    "features = [64, 128, 256, 512]\n",
    "num_epochs = 40\n",
    "\n",
    "if use_cuda:\n",
    "    try:\n",
    "        # Check free memory\n",
    "        free_mem = torch.cuda.mem_get_info()[0] / (1024**3) # in GB\n",
    "        if free_mem < 1.0:\n",
    "            print(f\"CUDA is available but only {free_mem:.2f} GB free VRAM. Falling back to CPU to avoid OOM.\")\n",
    "            use_cuda = False\n",
    "        else:\n",
    "            # Test allocation\n",
    "            x_test = torch.zeros((1, 3, 512, 512), device=\"cuda\")\n",
    "            del x_test\n",
    "            torch.cuda.empty_cache()\n",
    "    except Exception as e:\n",
    "        print(f\"CUDA is available but testing allocation failed: {e}. Falling back to CPU.\")\n",
    "        use_cuda = False\n",
    "\n",
    "device = torch.device(\"cuda\" if use_cuda else \"cpu\")\n",
    "print(f\"Using device: {device}\")\n",
    "\n",
    "if device.type == \"cpu\":\n",
    "    print(\"Using a lighter U-Net architecture and fewer epochs for faster CPU execution.\")\n",
    "    features = [32, 64, 128, 256]\n",
    "    num_epochs = 20\n",
    "else:\n",
    "    print(\"GPU Model:\", torch.cuda.get_device_name(0))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Dataset and Augmentation\n",
    "\n",
    "Since deep learning models need consistent shapes, we resize the inputs to $512 \\times 512$ pixels. To prevent overfitting on this small 20-image dataset, we use data augmentation. \n",
    "\n",
    "We implement a custom `Dataset` class. To ensure that the **same** random geometric transforms (flips, rotations) are applied to both the input image and its label mask, we use PyTorch's functional transforms."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-06-16T08:59:21.883031Z",
     "iopub.status.busy": "2026-06-16T08:59:21.882856Z",
     "iopub.status.idle": "2026-06-16T08:59:21.889706Z",
     "shell.execute_reply": "2026-06-16T08:59:21.889414Z"
    }
   },
   "outputs": [],
   "source": [
    "def create_retinal_mask(image_array: np.ndarray) -> np.ndarray:\n",
    "    gray = cv2.cvtColor(image_array, cv2.COLOR_BGR2GRAY)\n",
    "\n",
    "    blurred = cv2.medianBlur(gray, 11)\n",
    "    _, thresh = cv2.threshold(blurred, 45, 255, cv2.THRESH_BINARY)\n",
    "    contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n",
    "    \n",
    "    if not contours:\n",
    "        return np.zeros_like(gray, dtype=bool)\n",
    "    largest_contour = max(contours, key=cv2.contourArea)\n",
    "\n",
    "    mask_8u = np.zeros_like(gray)\n",
    "    cv2.drawContours(mask_8u, [largest_contour], -1, 255, thickness=cv2.FILLED)\n",
    "\n",
    "    kernel = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (5, 5))\n",
    "    mask_8u = cv2.erode(mask_8u, kernel, iterations=1)\n",
    "\n",
    "    return mask_8u > 0\n",
    "\n",
    "def apply_clahe(green: np.ndarray, mask: np.ndarray, clip_limit: float = 0.015, nbins: int = 256, kernel: int = 128) -> np.ndarray:\n",
    "    normalized = green.astype(float) / 255.0\n",
    "    normalized[~mask] = 0\n",
    "    enhanced = equalize_adapthist(normalized, kernel_size=kernel, clip_limit=clip_limit, nbins=nbins)\n",
    "    enhanced[~mask] = 0\n",
    "    return enhanced\n",
    "\n",
    "def preprocess_image(\n",
    "    image: np.ndarray, \n",
    "    mask: np.ndarray, \n",
    "    *, \n",
    "    clip_limit: float = 0.015, \n",
    "    nbins: int = 256, \n",
    "    kernel: int = 128, \n",
    "    gauss_size: tuple[int, int] = (51, 51),\n",
    "    median_blur_size: int = 5\n",
    ") -> np.ndarray:\n",
    "    img = image.astype(np.uint8)\n",
    "    img = cv2.medianBlur(img, median_blur_size)\n",
    "    bg_map = cv2.GaussianBlur(img, gauss_size, 0)\n",
    "    flat_bg = cv2.subtract(bg_map, img)\n",
    "    flat_bg = np.clip(flat_bg, 0, 255).astype(np.uint8)\n",
    "    flat_bg = cv2.medianBlur(flat_bg, median_blur_size)\n",
    "    clahe = apply_clahe(flat_bg, mask=mask, clip_limit=clip_limit, nbins=nbins, kernel=kernel)\n",
    "    return clahe\n",
    "\n",
    "class RetinalDataset(Dataset):\n",
    "    def __init__(self, image_dir, label_dir, image_ids, transform=False, target_size=(512, 512)):\n",
    "        self.image_dir = Path(image_dir)\n",
    "        self.label_dir = Path(label_dir)\n",
    "        self.image_ids = image_ids\n",
    "        self.transform = transform\n",
    "        self.target_size = target_size\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.image_ids)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        img_id = self.image_ids[idx]\n",
    "        img_path = self.image_dir / f\"{img_id}.ppm\"\n",
    "        lbl_path = self.label_dir / f\"{img_id}.vk.ppm\"\n",
    "\n",
    "        # Load image and label\n",
    "        image_pil = Image.open(img_path).convert(\"RGB\")\n",
    "        label_pil = Image.open(lbl_path).convert(\"L\")\n",
    "\n",
    "        # Resize\n",
    "        image_pil = TF.resize(image_pil, self.target_size)\n",
    "        label_pil = TF.resize(label_pil, self.target_size, interpolation=TF.InterpolationMode.NEAREST)\n",
    "\n",
    "        # Convert image to numpy array for mask creation and CLAHE preprocessing\n",
    "        img_np = np.array(image_pil)\n",
    "        \n",
    "        # Create retinal mask\n",
    "        retinal_mask_np = create_retinal_mask(img_np)\n",
    "        \n",
    "        # Extract green channel\n",
    "        green = img_np[:, :, 1]\n",
    "        \n",
    "        # Preprocess green channel using mask\n",
    "        preprocessed = preprocess_image(green, retinal_mask_np)\n",
    "        \n",
    "        # Convert preprocessed float array back to PIL Image and convert to RGB (3 channels)\n",
    "        preprocessed_uint8 = (preprocessed * 255).astype(np.uint8)\n",
    "        image = Image.fromarray(preprocessed_uint8).convert(\"RGB\")\n",
    "        label = label_pil\n",
    "        \n",
    "        # Convert retinal mask to PIL Image for joint augmentations\n",
    "        retinal_mask_pil = Image.fromarray((retinal_mask_np * 255).astype(np.uint8))\n",
    "\n",
    "        # Apply joint augmentations if training\n",
    "        if self.transform:\n",
    "            # Random horizontal flipping\n",
    "            if random.random() > 0.5:\n",
    "                image = TF.hflip(image)\n",
    "                label = TF.hflip(label)\n",
    "                retinal_mask_pil = TF.hflip(retinal_mask_pil)\n",
    "\n",
    "            # Random vertical flipping\n",
    "            if random.random() > 0.5:\n",
    "                image = TF.vflip(image)\n",
    "                label = TF.vflip(label)\n",
    "                retinal_mask_pil = TF.vflip(retinal_mask_pil)\n",
    "\n",
    "            # Random rotation\n",
    "            if random.random() > 0.5:\n",
    "                angle = random.randint(-30, 30)\n",
    "                image = TF.rotate(image, angle)\n",
    "                label = TF.rotate(label, angle)\n",
    "                retinal_mask_pil = TF.rotate(retinal_mask_pil, angle)\n",
    "\n",
    "        # Convert to tensor\n",
    "        image = TF.to_tensor(image)  # converts to [0.0, 1.0]\n",
    "        label = TF.to_tensor(label)  # converts to [0.0, 1.0]\n",
    "        retinal_mask = TF.to_tensor(retinal_mask_pil)  # converts to [0.0, 1.0]\n",
    "\n",
    "        # Binarize target and mask to ensure strictly 0 and 1\n",
    "        label = (label > 0.5).float()\n",
    "        retinal_mask = (retinal_mask > 0.5).float()\n",
    "\n",
    "        return image, label, retinal_mask"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Train / Validation Split\n",
    "\n",
    "We list the available image IDs and split them: 15 images for training and 5 for validation."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-06-16T08:59:21.890652Z",
